<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorPrimaryDark">@color/primaryDarkColor</item>
        <item name="colorSecondary">@color/secondaryLightColor</item>
        <item name="colorAccent">@color/colorAccent</item>
        <!-- Dark background -->
        <item name="android:windowBackground">@color/secondaryDarkColor</item>
        
        <!-- Customize status bar for dark mode -->
        <item name="android:statusBarColor">@color/secondaryDarkColor</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
</resources>